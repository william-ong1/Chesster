{
  "name": "chess-mimic",
  "version": "1.0.0",
  "description": "Train a chess engine on your games and play against it.",
  "main": "app/main.js",
  "type": "commonjs",
  "author": "Shreyan Mitra, William Ong, Danyuan Wang, Mason Tepper, Raghav Ramesh, Lebam Amare",
  "license": "ISC",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder -mwl",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint app/ tests/"
  },

  "dependencies": {
    "chess.js": "0.10.3",
    "electron-squirrel-startup": "^1.0.1"
  },

  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "typescript": "^5.7.0"
  },

  "build": {
    "appId": "com.chessmimic.app",
    "productName": "Chess Mimic",

    "directories": {
      "output": "dist"
    },

    "files": [
      "app/**/*",
      "scripts/**/*",
      "node_modules/**/*"
    ],

    "extraResources": [
      { "from": "bin/", "to": "bin/" },
      { "from": "maia-individual/", "to": "maia-individual/" },
      { "from": "models/", "to": "models/" }
    ],

    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.games"
    },

    "win": {
      "target": ["nsis"]
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },

    "linux": {
      "target": ["AppImage"],
      "category": "Game"
    }
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/william-ong1/Chesster"
  },

  "bugs": {
    "url": "https://github.com/william-ong1/Chesster/issues"
  },

  "homepage": "https://github.com/william-ong1/Chesster"
}